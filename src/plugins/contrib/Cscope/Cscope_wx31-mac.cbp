<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Cscope wx3.1.x (Mac OS)" />
		<Option platforms="Mac;" />
		<Option pch_mode="2" />
		<Option compiler="clang" />
		<Build>
			<Target title="default">
				<Option output="../../../devel31/share/codeblocks/plugins/Cscope" prefix_auto="1" extension_auto="1" />
				<Option object_output="../../../.objs31/plugins/contrib/Cscope" />
				<Option type="3" />
				<Option compiler="clang" />
				<Option parameters="--debug-log --multiple-instance -ns -ni -p debug" />
				<Option host_application="../../../devel31/codeblocks" />
				<Option run_host_application_in_terminal="0" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="$(#CB_RELEASE_TYPE)" />
					<Add option="`$(#WX_CONFIG) --cflags`" />
					<Add option="-Winvalid-pch" />
					<Add option="-fexceptions" />
					<Add option="-fPIC" />
					<Add option="-DCB_PRECOMP" />
					<Add option="-DcbDEBUG" />
					<Add directory="../../../include" />
					<Add directory="../../../include/tinyxml" />
					<Add directory="../../../sdk/wxscintilla/include" />
				</Compiler>
				<Linker>
					<Add option="`$(#WX_CONFIG) --libs`" />
					<Add library="codeblocks" />
					<Add directory="../../../devel31" />
				</Linker>
				<ExtraCommands>
					<Add after="zip -jq9 ../../../devel31/share/codeblocks/Cscope.zip manifest.xml" />
					<Mode after="always" />
				</ExtraCommands>
			</Target>
		</Build>
		<VirtualTargets>
			<Add alias="All" targets="default;" />
		</VirtualTargets>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-std=c++11" />
			<Add option="-Wextra" />
			<Add option="$(#CB_RELEASE_TYPE)" />
			<Add option="-mmacosx-version-min=10.7" />
			<Add option="-stdlib=libc++" />
		</Compiler>
		<Linker>
			<Add option="-Wl,-headerpad_max_install_names" />
			<Add option="-mmacosx-version-min=10.7" />
			<Add option="-stdlib=libc++" />
		</Linker>
		<Unit filename="CscopeConfig.cpp" />
		<Unit filename="CscopeConfig.h" />
		<Unit filename="CscopeEntryData.cpp" />
		<Unit filename="CscopeEntryData.h" />
		<Unit filename="CscopeParserThread.cpp" />
		<Unit filename="CscopeParserThread.h" />
		<Unit filename="CscopePlugin.cpp" />
		<Unit filename="CscopePlugin.h" />
		<Unit filename="CscopeProcess.cpp" />
		<Unit filename="CscopeProcess.h" />
		<Unit filename="CscopeStatusMessage.cpp" />
		<Unit filename="CscopeStatusMessage.h" />
		<Unit filename="CscopeTab.cpp" />
		<Unit filename="CscopeTab.h" />
		<Unit filename="CscopeView.cpp" />
		<Unit filename="CscopeView.h" />
		<Unit filename="manifest.xml" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
