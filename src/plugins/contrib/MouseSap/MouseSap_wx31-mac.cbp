<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="MouseSap wx3.1.x (Mac OS)" />
		<Option platforms="Mac;" />
		<Option pch_mode="0" />
		<Option compiler="clang" />
		<Build>
			<Target title="default">
				<Option output="../../../devel31/share/codeblocks/plugins/MouseSap" prefix_auto="1" extension_auto="1" />
				<Option object_output="../../../.objs31/plugins/contrib/MouseSap" />
				<Option type="3" />
				<Option compiler="clang" />
				<Option parameters="--debug-log --multiple-instance -ns -ni -p debug" />
				<Option host_application="../../../devel31/codeblocks" />
				<Option run_host_application_in_terminal="0" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-std=c++11" />
					<Add option="-fPIC" />
					<Add option="-Wextra" />
					<Add option="`$(#WX_CONFIG) --cflags`" />
					<Add option="-fexceptions" />
					<Add option="-Winvalid-pch" />
					<Add option="-DcbDEBUG" />
					<Add option="-DCB_PRECOMP" />
					<Add directory="../../../include" />
					<Add directory="../../../include/tinyxml" />
					<Add directory="../../../sdk/wxscintilla/include" />
				</Compiler>
				<Linker>
					<Add option="`$(#WX_CONFIG) --libs`" />
					<Add library="codeblocks" />
					<Add directory="../../../devel31" />
				</Linker>
				<ExtraCommands>
					<Add after="zip -j9 ../../../devel31/share/codeblocks/MouseSap.zip manifest.xml" />
					<Mode after="always" />
				</ExtraCommands>
			</Target>
		</Build>
		<VirtualTargets>
			<Add alias="All" targets="default;" />
		</VirtualTargets>
		<Compiler>
			<Add option="-std=c++11" />
			<Add option="$(#CB_RELEASE_TYPE)" />
			<Add option="-mmacosx-version-min=10.7" />
			<Add option="-stdlib=libc++" />
		</Compiler>
		<Linker>
			<Add option="-Wl,-headerpad_max_install_names" />
			<Add option="-mmacosx-version-min=10.7" />
			<Add option="-stdlib=libc++" />
		</Linker>
		<Unit filename="MouseSap.cpp" />
		<Unit filename="MouseSap.h" />
		<Unit filename="manifest.xml" />
		<Extensions>
			<code_completion />
			<envvars />
			<debugger />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
